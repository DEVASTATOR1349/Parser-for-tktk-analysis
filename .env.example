GOOGLE_APPLICATION_CREDENTIALS=/app/config/service_account.json
APIFY_API_TOKEN=apify_api_...
YOUTUBE_API_KEY=...
VK_API_TOKEN=...

# Option A: load clients from master Google Sheet (recommended for 25+ clients)
CLIENTS_SHEET_ID=1E4TmhKLulzI9y7ag3yJJPIt8LmL_DGm1kzjuOFgOxMM

# Option B: load from local YAML (used if CLIENTS_SHEET_ID is empty)
# CLIENTS_CONFIG=/app/config/clients.yaml

SCOUT_EXTRA_ENV_FILE=
# Delay between clients to avoid Sheets API quota (seconds, default 3)
SCOUT_INTER_CLIENT_DELAY_SEC=3
